{
  "name": "flood-monitoring-monorepo",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "mobile": "pnpm --filter flood-warning-app start",
    "mobile:android": "pnpm --filter flood-warning-app android",
    "mobile:ios": "pnpm --filter flood-warning-app ios",
    "crm": "pnpm --filter flood-management-crm dev",
    "api": "cd apps/api && ./mvnw spring-boot:run",
    "packages:build": "turbo run build --filter='./packages/*'"
  },
  "devDependencies": {
    "turbo": "^2.5.4",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
