# Copy this file to .env and fill in real values
# Never commit .env to git

# ── Neon PostgreSQL (JDBC format) ─────────────────────────────────────────────
# Get from: neon.tech → your project → Connection Details → Java / JDBC
DATABASE_URL=jdbc:postgresql://HOST/DBNAME?sslmode=require&user=YOUR_USER&password=YOUR_PASSWORD

# ── JWT secrets ───────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_to_random_64_char_hex_string
JWT_REFRESH_SECRET=change_me_to_another_random_64_char_hex_string

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Redis (Upstash) ───────────────────────────────────────────────────────────
# Get from: upstash.com → Create Database → Redis → .env tab → UPSTASH_REDIS_URL
# Format: rediss://default:TOKEN@HOST:PORT
# Leave empty to use in-memory cache (local dev — no Redis needed)
REDIS_URL=

# ── Resend email ──────────────────────────────────────────────────────────────
# Get from: resend.com → API Keys → Create API Key
# Leave empty in development — reset codes are logged to console instead
RESEND_API_KEY=

# From-address — must match a verified domain in your Resend account
# In development this is unused (emails are logged, not sent)
EMAIL_FROM=noreply@yourdomain.com
